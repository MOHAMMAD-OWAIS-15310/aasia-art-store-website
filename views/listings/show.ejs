<% layout("/layouts/boilerplate") %>
<body>
   
   <div class="row mt-3">
      <div class="col-8 offset-2">
         
         <h2><%=listing.title%></h2>
         <div class="card listing-card" style="width: 18rem;">
            <img src="<%=listing.image%>" class="card-img-top show-img" alt="listing_image">
            <div class="card-body listing-card-body">
               <div class="all-li">
                  <ul>
                     <li>price : &#8377;<%=listing.price.toLocaleString("en-IN")%></li>
                     <li>size : <%=listing.size%></li>
                     <li>medium : <%=listing.medium%></li>
                     <li>Available? <%=listing.available%></li>
                  </ul>
               </div>
               <div class="show-button">
                  <form method="get" action="/listings/<%=listing.id%>/payment">
                     <button class="btn btn-dark buy-btn-show">Buy Now</button>
                  </form><br>
                  <form method="post" action="/listings/<%=listing.id%>/save">
                     <button class="btn btn-success">Save Painting</button>
                  </form><br>
                  <form method="get" action="/listings/<%=listing.id%>/edit">
                     <button class="btn btn-danger">edit</button>
                  </form><br>
                  <form method="post" action="/listings/<%=listing._id%>?_method=DELETE">
                     <button class="btn btn-danger">delete</button>
                  </form>
               </div>
            </div>
         </div>

         <div>
            <hr>
            <h4>Give a Review</h4>
            <form action="/listings/<%=listing.id%>/reviews" method="post" novalidate class="needs-validation">
               <div>
                  <label for="rating" class="form-label">Rating</label>
                  <input type="range" min="1" max="5" id="rating" name="review[rating]" >
               </div>
               <div>
                  <label for="comment" class="form-label">Comment</label><br>
                  <textarea name="review[comment]" id="comment" cols="60" rows="5" class="form-control" required></textarea>
                  <div class="invalid-feedback">Please type something in Comment</div>
               </div>
               <br>
               <button class="btn btn-dark">Submit</button>
            </form>
         </div>
         <br><br>
         <div>
            <h4><b>All Reviews</b></h4>
            <div class="row">
               <% for( review of listing.reviews){ %>
                  <div class="card  col-5 mb-2 mt-2 m-2">
                     <div class="card-body">
                        <h5 class="card-title">owais</h5>
                        <p class="card-text"><%= review.comment %> </p>
                        <p class="card-text"><%= review.rating %> stars </p>
                     </div>
                     <form method="post" action="/listings/<%=listing.id%>/reviews/<%=review.id%>?_method=delete">
                        <button class="btn btn-danger mb-2">delete</button>
                     </form>
                     
                  </div>
               <%}%>
            </div>
         </div>
      </div>
   </div>
</body>
