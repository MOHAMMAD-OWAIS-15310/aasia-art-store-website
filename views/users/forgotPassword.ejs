<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <h1>Forgot Password</h1>
        <form action="/forgot-password" method="post" class="needs-validation" novalidate>
            <label for="email" class="form-label">Email</label>
            <input name="email" type="email" placeholder="Enter email"  type="email" class="form-control" required>
            <button class="btn btn-danger mt-3">Send Reset Link</button>
        </form>
    </div>
</div>