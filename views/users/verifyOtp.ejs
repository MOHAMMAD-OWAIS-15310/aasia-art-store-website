<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-8 offset-2">
    <h1 class="mb-5">Verify Email</h1>

    <form action="/verify-otp" method="post">
        <div class="mt-2">
             <label class="form-label">Enter OTP sent to your email</label>
            <input name="otp" type="text" class="form-control" required>
        </div>

        <button class="btn btn-success mt-3">Verify</button>
    </form>

  </div>
</div>